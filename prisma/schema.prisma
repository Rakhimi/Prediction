// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Member {
  id                  Int      @id @default(autoincrement())
  providerUid         String   @unique
  username            String?  // <- new optional field
  accessUntil         DateTime?
  isMember            Boolean  @default(false)
  ftdAmount           String   @default("0.00")
  recentDepositAmount String   @default("0.00")
  lastSyncedAt        DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("member")
}

model Match {
  id         Int      @id @default(autoincrement())
  matchId    Int      @unique

  league     String

  homeTeam   String
  awayTeam   String
  matchDate  DateTime

  // Form
  homeTeamForm   String?
  awayTeamForm   String?

  // Odds
  homeOdds   Float?
  drawOdds   Float?
  awayOdds   Float?

  over25Odds Float?
  under25Odds Float?

  // AI Probabilities
  homeWinProb Float?
  drawProb    Float?
  awayWinProb Float?

  // Head-to-head
  headToHead  String[]

  // AI Prediction (NEW)
  correctScore String?
  ftHandicap   String?
  bestBet      String?

  // Analysis
  analysis   String?

  analyzed   Boolean  @default(false)

  createdAt  DateTime @default(now())

  @@map("match")
}
